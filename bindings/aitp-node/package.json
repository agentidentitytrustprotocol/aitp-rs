{
  "name": "@agentidentitytrustprotocol/aitp",
  "version": "0.4.0",
  "description": "Agent Identity Trust Protocol — Node.js SDK",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentidentitytrustprotocol/aitp-rs.git",
    "directory": "bindings/aitp-node"
  },
  "homepage": "https://github.com/agentidentitytrustprotocol/aitp-rs/tree/main/bindings/aitp-node",
  "main": "index.js",
  "types": "index.d.ts",
  "type": "commonjs",
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "napi": {
    "name": "aitp",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:minimal": "napi build --platform --release --no-default-features",
    "build:minimal:debug": "napi build --platform --no-default-features",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version",
    "test": "node --test tests/*.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "node-forge": "^1.4.0"
  },
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "jose": "^6.2.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "optionalDependencies": {
    "@agentidentitytrustprotocol/aitp-darwin-x64": "0.4.1",
    "@agentidentitytrustprotocol/aitp-darwin-arm64": "0.4.1",
    "@agentidentitytrustprotocol/aitp-linux-x64-gnu": "0.4.1",
    "@agentidentitytrustprotocol/aitp-linux-arm64-gnu": "0.4.1"
  }
}
