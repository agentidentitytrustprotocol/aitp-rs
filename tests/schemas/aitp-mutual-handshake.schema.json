{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.dev/schema/v0.2/mutual-handshake.json",
  "title": "MutualHandshakeMessages",
  "description": "AITP v0.2 Mutual Handshake payload schemas. Four message types: mutual_hello, mutual_hello_ack, mutual_commit, mutual_commit_ack. Commit payloads carry the peer's TCT (and optional grant voucher) as opaque compact JWS strings (RFC-AITP-0001 §5.4.5).",
  "$defs": {
    "IdentityDescriptor": {
      "type": "object",
      "required": [
        "type",
        "subject",
        "proof"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "oidc",
            "pinned_key"
          ]
        },
        "issuer": {
          "type": "string",
          "format": "uri"
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "proof": {
          "type": "string",
          "minLength": 1
        },
        "public_key": {
          "type": "string"
        }
      },
      "if": {
        "properties": {
          "type": {
            "const": "oidc"
          }
        }
      },
      "then": {
        "required": [
          "issuer"
        ]
      },
      "else": {
        "required": [
          "public_key"
        ]
      },
      "additionalProperties": false
    },
    "CompactJws": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+$",
      "description": "RFC 7515 compact JWS: exactly three non-empty unpadded-base64url segments. Embedded verbatim as an opaque string; the envelope layer never decodes or re-encodes it."
    },
    "PopNonce": {
      "type": "string",
      "minLength": 22,
      "description": "Random 128-bit value encoded as base64url (minimum 22 chars).",
      "pattern": "^[A-Za-z0-9_-]{22}$"
    },
    "PopSignature": {
      "type": "string",
      "minLength": 1,
      "description": "base64url(sign(private_key, sha256(peer_pop_nonce))). Proves possession of the private key for this agent's AID. MAY carry a v0.2 algorithm tag prefix (RFC-AITP-0001 §5.4.3).",
      "pattern": "^((ed25519|p256)\\.)?[A-Za-z0-9_-]{86}$"
    },
    "MutualHelloPayload": {
      "type": "object",
      "required": [
        "identity",
        "manifest",
        "requested_grants",
        "pop_nonce"
      ],
      "properties": {
        "identity": {
          "$ref": "#/$defs/IdentityDescriptor"
        },
        "manifest": {
          "description": "Initiator's Agent Manifest inline.",
          "type": "object"
        },
        "requested_grants": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[^\\s]+$"
          },
          "uniqueItems": true
        },
        "pop_nonce": {
          "$ref": "#/$defs/PopNonce"
        },
        "extensions": {
          "type": "object",
          "description": "Optional extension namespace per RFC-AITP-0001 §7 and RFC-AITP-0012."
        }
      },
      "additionalProperties": false
    },
    "MutualHelloAckPayload": {
      "type": "object",
      "required": [
        "identity",
        "manifest",
        "requested_grants",
        "pop_nonce",
        "pop_nonce_echo"
      ],
      "properties": {
        "identity": {
          "$ref": "#/$defs/IdentityDescriptor"
        },
        "manifest": {
          "description": "Target's Agent Manifest inline.",
          "type": "object"
        },
        "requested_grants": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[^\\s]+$"
          },
          "uniqueItems": true
        },
        "pop_nonce": {
          "$ref": "#/$defs/PopNonce",
          "description": "Target's nonce. Initiator must sign this in MUTUAL_COMMIT."
        },
        "pop_nonce_echo": {
          "$ref": "#/$defs/PopNonce",
          "description": "MUST equal initiator's pop_nonce from MUTUAL_HELLO."
        },
        "extensions": {
          "type": "object",
          "description": "Optional extension namespace per RFC-AITP-0001 §7 and RFC-AITP-0012."
        }
      },
      "additionalProperties": false
    },
    "MutualCommitPayload": {
      "type": "object",
      "required": [
        "tct",
        "pop_signature",
        "pop_nonce_echo"
      ],
      "properties": {
        "tct": {
          "$ref": "#/$defs/CompactJws",
          "description": "TCT the initiator issues for the target — compact JWS, typ 'aitp-tct+jwt' (RFC-AITP-0005). Decoded claims validate against aitp-tct.schema.json."
        },
        "grant_voucher": {
          "$ref": "#/$defs/CompactJws",
          "description": "OPTIONAL grant voucher minted alongside the TCT — compact JWS, typ 'aitp-grant+jwt' (RFC-AITP-0005 §8). Omitted when issuer policy forbids the subject from delegating. Decoded claims validate against aitp-grant-voucher.schema.json."
        },
        "pop_signature": {
          "$ref": "#/$defs/PopSignature",
          "description": "base64url(sign(A_key, sha256(B_pop_nonce)))."
        },
        "pop_nonce_echo": {
          "$ref": "#/$defs/PopNonce",
          "description": "MUST equal target's pop_nonce from MUTUAL_HELLO_ACK."
        },
        "extensions": {
          "type": "object",
          "description": "Optional extension namespace per RFC-AITP-0001 §7 and RFC-AITP-0012."
        }
      },
      "additionalProperties": false
    },
    "MutualCommitAckPayload": {
      "type": "object",
      "required": [
        "tct",
        "pop_signature",
        "pop_nonce_echo"
      ],
      "properties": {
        "tct": {
          "$ref": "#/$defs/CompactJws",
          "description": "TCT the target issues for the initiator — compact JWS, typ 'aitp-tct+jwt' (RFC-AITP-0005)."
        },
        "grant_voucher": {
          "$ref": "#/$defs/CompactJws",
          "description": "OPTIONAL grant voucher minted alongside the TCT — compact JWS, typ 'aitp-grant+jwt' (RFC-AITP-0005 §8)."
        },
        "pop_signature": {
          "$ref": "#/$defs/PopSignature",
          "description": "base64url(sign(B_key, sha256(A_pop_nonce)))."
        },
        "pop_nonce_echo": {
          "$ref": "#/$defs/PopNonce",
          "description": "MUST equal initiator's pop_nonce from MUTUAL_HELLO."
        },
        "extensions": {
          "type": "object",
          "description": "Optional extension namespace per RFC-AITP-0001 §7 and RFC-AITP-0012."
        }
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    {
      "title": "MutualHello (message_type=mutual_hello)",
      "$ref": "#/$defs/MutualHelloPayload"
    },
    {
      "title": "MutualHelloAck (message_type=mutual_hello_ack)",
      "$ref": "#/$defs/MutualHelloAckPayload"
    },
    {
      "title": "MutualCommit (message_type=mutual_commit)",
      "$ref": "#/$defs/MutualCommitPayload"
    },
    {
      "title": "MutualCommitAck (message_type=mutual_commit_ack)",
      "$ref": "#/$defs/MutualCommitAckPayload"
    }
  ],
  "examples": [
    {
      "title": "MutualHello — OIDC",
      "identity": {
        "type": "oidc",
        "issuer": "https://auth.openai.com",
        "subject": "agent-A",
        "proof": "eyJhbGciOiJFZERTQSJ9..."
      },
      "manifest": {
        "version": "aitp/0.2",
        "aid": "aid:pubkey:agentA_pubkey_AID_v01_placeholder_AAAAAAAAA",
        "signature": "sig_A_manifest_v01_placeholder_AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
      },
      "requested_grants": [
        "macp.mode.task.v1",
        "read_data"
      ],
      "pop_nonce": "nonce_A_pop_v01_aaannn"
    },
    {
      "title": "MutualCommit",
      "tct": "eyJhbGciOiJFZERTQSIsInR5cCI6ImFpdHAtdGN0K2p3dCJ9.eyJ2ZXIiOiJhaXRwLzAuMiJ9.tct_jws_signature_placeholder",
      "grant_voucher": "eyJhbGciOiJFZERTQSIsInR5cCI6ImFpdHAtZ3JhbnQrand0In0.eyJ2ZXIiOiJhaXRwLzAuMiJ9.voucher_jws_signature_placeholder",
      "pop_signature": "sig_A_pop_v01_placeholder_AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
      "pop_nonce_echo": "nonce_B_pop_v01_aaannn"
    }
  ]
}
