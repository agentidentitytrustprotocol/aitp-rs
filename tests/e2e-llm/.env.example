# Tier-3 LLM-driven e2e tests for aitp-rs.
#
# Copy this file to `.env` (gitignored at the repo root) and fill in
# at least one provider key. The tests skip-by-default; set
# AITP_RUN_LLM_TESTS=1 to actually run them.

# Master gate. Without this, every test in this package exits as a
# no-op skip and burns no API credits.
AITP_RUN_LLM_TESTS=0

# At least one of these must be set when AITP_RUN_LLM_TESTS=1.
# If both are set, ANTHROPIC_API_KEY wins (Claude is the default).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional model overrides.
# Defaults: claude-haiku-4-5 (Anthropic) / gpt-4o-mini (OpenAI).
# AITP_LLM_MODEL=
